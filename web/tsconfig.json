{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@commons/app-kit": ["../packages/app-kit/src/index.ts"],
      "@commons/os": ["../packages/os/src/index.ts"]
    }
  },
  "include": ["src", "../packages"]
}
